# MongoDB
CONNECTION_STRING="mongodb+srv://<user>:<password>@cluster0...mongodb.net/?appName=Cluster0"

# Pinecone
PINECONE_API_KEY="your_pinecone_api_key_here"
USE_RERANKING=False

# Base LLM Generation (Groq)
GROQ_API_KEY="your_groq_api_key_here"
OPENAI_MODEL_GROQ="openai/gpt-oss-120b"
TEMPERATURE=0.2
MAX_TOKENS=1024

# --- Optional Role-Specific Configurations ---
# If left blank, these will default to your base GROQ keys and models above.

# Adaptive RAG Router Override
# ADAPTIVE_RAG_API_KEY="your_router_api_key"
# ADAPTIVE_RAG_MODEL="your_model"
# ADAPTIVE_RAG_TEMPERATURE=0.0
# ADAPTIVE_RAG_MAX_TOKENS=512

# Corrective RAG (CRAG) Document Grader Override
# CRAG_API_KEY="your_evaluator_api_key"
# CRAG_MODEL="your_model"
# CRAG_TEMPERATURE=0.0
# CRAG_MAX_TOKENS=512

# Self-RAG Evaluation & Rewriting Override
# SELF_RAG_API_KEY="your_self_rag_api_key"
# SELF_RAG_MODEL="your_model"
# SELF_RAG_TEMPERATURE=0.0
# SELF_RAG_MAX_TOKENS=512